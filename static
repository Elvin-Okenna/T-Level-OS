##CENTERING CONTENT####
.container {
    width: 80%;
    margin: 0 auto; /* centers horizontally */
}

FLEXBOX LAYOUT####
.box {
    display: flex;
    justify-content: center; /* horizontal */
    align-items: center;     /* vertical */
}

BUTTON STYLING#######
button {
    background: #2ecc71;
    color: white;
    padding: 10px 20px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
}
button:hover {
    background: #27ae60;
}
